# Configuration d'exemple pour PacingScore Backend
# ⚠️ Copiez ce fichier en application.properties et remplacez les valeurs par vos vraies clés
# Ou utilisez les variables d'environnement correspondantes

# Supabase
supabase.url=https://votre-projet.supabase.co
supabase.key=sb_publishable_...

# TMDB
tmdb.api.key=your_tmdb_api_key_here
tmdb.api.url=https://api.themoviedb.org/3

# Analyzer
video.analyzer.temp-dir=./temp/videos
video.analyzer.max-duration=300

# Server
server.port=8080
spring.application.name=pacingscore

# Logging
logging.level.com.pacingscore=INFO
